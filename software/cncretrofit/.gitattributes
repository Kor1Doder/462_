# Normalize line endings to LF in the repository and the working tree on every
# platform. Without this, Windows checkouts get CRLF while Linux gets LF, which
# makes `ruff format --check` and the Windows/Linux CI matrix disagree
#.
* text=auto eol=lf

# Lockfile is generated; keep diffs collapsed in review tools.
uv.lock linguist-generated=true
